// DFROBOT V2 쉴드 오른쪽(M2/Y축) 모터 전용 핀
int enablePin = 12; // 깨우기/재우기 핀
int stepPin = 5;    // 박자(이동) 핀
int dirPin = 4;     // 방향 핀

// 모터의 작동 상태를 기억하는 변수 (처음에는 안전을 위해 꺼둠)
bool isRunning = false; 

void setup() {
  // 💡 컴퓨터와 아두이노의 통신 속도를 9600으로 맞추어 '채팅방'을 엽니다.
  Serial.begin(9600); 

  pinMode(enablePin, OUTPUT);
  pinMode(stepPin, OUTPUT);
  pinMode(dirPin, OUTPUT);
  
  digitalWrite(dirPin, HIGH);   // 방향 설정
  digitalWrite(enablePin, HIGH); // 처음엔 힘을 풀고(Disable) 대기
  
  // 컴퓨터 화면에 안내 메시지 띄우기
  Serial.println("===== PC 제어 시스템 준비 완료 =====");
  Serial.println("숫자 '1'을 전송하면 작동을 시작합니다.");
  Serial.println("숫자 '0'을 전송하면 즉시 정지합니다.");
}

void loop() {
  // 1단계: 컴퓨터(노트북)로부터 날아온 메시지가 있는지 확인
  if (Serial.available() > 0) {
    char command = Serial.read(); // 날아온 글자 하나를 읽음
    
    // 명령어가 '1'일 때 -> 구동 시작
    if (command == '1') {
      isRunning = true;
      digitalWrite(enablePin, LOW); // 드라이버 깨우기 (힘 주기)
      Serial.println("명령 수신: ▶️ 모터 구동 시작!");
    }
    // 명령어가 '0'일 때 -> 즉시 정지
    else if (command == '0') {
      isRunning = false;
      digitalWrite(enablePin, HIGH); // 드라이버 재우기 (힘 풀기)
      Serial.println("명령 수신: 🛑 긴급 정지 완료!");
    }
  }

  // 2단계: isRunning이 true일 때만 계속 회전
  if (isRunning == true) {
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(2000); 
    digitalWrite(stepPin, LOW);
    delayMicroseconds(2000); 
  }
}
