#include <AccelStepper.h>

// ⚠️ 중요: 현재 장착한 쉴드의 사양에 맞게 Step 핀과 Dir 핀 번호를 확인 후 수정해야 합니다.
// (일반적인 CNC/스텝모터 쉴드는 X축 기준 2번, 5번 핀을 많이 사용합니다.)
const int stepPin = 2; 
const int dirPin = 5;  

// 외부 드라이버 모드(인터페이스 타입 1)로 스텝모터 객체 선언
AccelStepper myStepper(1, stepPin, dirPin);

void setup() {
  Serial.begin(9600);
  
  // 모터의 동작 성능 설정
  myStepper.setMaxSpeed(1000);     // 초당 최대 스텝 수 (속도의 상한선)
  myStepper.setAcceleration(300);  // 초당 속도 증가량 (가속도가 클수록 빠르게 최고 속도에 도달)

  Serial.println("===== 스텝 모터 가속 테스트 시작 =====");
  
  // 최초 목표 위치 설정: 2000 스텝 위치로 이동 명령 (1.8도 모터 기준 10바퀴)
  myStepper.moveTo(2000); 
}

void loop() {
  // run() 함수는 loop 안에서 최대한 빠르게 반복 호출되어야 합니다.
  // 이 함수가 실행되면서 내부적으로 현재 시간에 맞춰 속도를 계산하고 모터에 한 스텝씩 신호를 보냅니다.
  myStepper.run();

  // 설정한 목표 위치(distanceToGo가 0)에 도달했는지 확인
  if (myStepper.distanceToGo() == 0) {
    delay(1000); // 목표 위치 도달 후 1초간 정지 대기
    
    // 현재 위치가 2000이면 다시 0원으로, 0이면 다시 2000으로 목표를 전환하여 왕복 운동
    if (myStepper.currentPosition() == 2000) {
      Serial.println("반대 방향으로 가속 회전 시작 (목표: 0 스텝)");
      myStepper.moveTo(0);
    } else {
      Serial.println("정방향으로 가속 회전 시작 (목표: 2000 스텝)");
      myStepper.moveTo(2000);
    }
  }
}
