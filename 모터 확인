// 쉴드와 연결된 핀 번호 설정 (가장 흔하게 쓰이는 기본 핀 배열입니다)
int enablePin = 8; // 모터에 힘을 넣는(활성화) 핀
int stepPin = 2;   // 박자를 만들어내는(속도/이동) 핀
int dirPin = 5;    // 방향을 결정하는 핀

void setup() {
  // 3개의 핀을 모두 출력(신호를 내보내는) 모드로 설정
  pinMode(enablePin, OUTPUT);
  pinMode(stepPin, OUTPUT);
  pinMode(dirPin, OUTPUT);

  // 1. 모터 깨우기 (LOW 신호를 주어야 모터가 꽉 잠기며 작동 준비를 합니다)
  digitalWrite(enablePin, LOW); 

  // 2. 방향 설정 (HIGH면 시계방향, LOW면 반시계방향)
  digitalWrite(dirPin, HIGH); 
}

void loop() {
  // 3. 모터 돌리기 (무한 반복)
  // 전기를 켰다가(HIGH) 껐다가(LOW) 하면서 1스텝씩 움직이게 합니다.
  
  digitalWrite(stepPin, HIGH);
  delayMicroseconds(1000);      // 1000 마이크로초(0.001초) 대기
  
  digitalWrite(stepPin, LOW);
  delayMicroseconds(1000);      // 1000 마이크로초 대기
  
  // 이 속도가 너무 빠르면 삐- 소리만 나고 안 돌 수 있습니다. 
  // 만약 안 돈다면 숫자 1000을 2000이나 3000으로 늘려보세요.
}
